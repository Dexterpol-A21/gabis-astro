---
const mapSrc =
    "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d14948.777083072382!2d-99.0664673!3d19.6231641!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85d1f3006520c2d5%3A0xcbaab4aeec6c7d2b!2sGabis!5e0!3m2!1ses-419!2smx!4v1769720021160!5m2!1ses-419!2smx";
---

<section
    class="py-20 transition-colors duration-500"
    style="background-color: var(--theme-bg); color: var(--theme-text);"
>
    <div
        class="max-w-7xl mx-auto px-6 md:px-4 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center"
    >
        <!-- Text Content -->
        <div>
            <h2
                class="text-5xl md:text-7xl mb-8 leading-none transition-all duration-500"
                style="font-family: var(--theme-font-title); color: var(--theme-text);"
            >
                VISÍTANOS EN <br />
                <span style="color: var(--theme-accent);"
                    >ECATEPEC / COACALCO</span
                >
            </h2>

            <div class="space-y-8 font-satoshi text-lg opacity-90">
                <div>
                    <h3
                        class="text-2xl mb-2 tracking-wide transition-all duration-500"
                        style="font-family: var(--theme-font-title); color: var(--theme-text);"
                    >
                        DIRECCIÓN
                    </h3>
                    <p>
                        Cerca de, De Los Trabajadores Casi Esquina Rafael
                        Valdovinos S/N,
                    </p>
                    <p>Guadalupe Victoria, 55010 Ecatepec de Morelos, Méx.</p>
                </div>

                <div>
                    <h3
                        class="text-2xl mb-2 tracking-wide transition-all duration-500"
                        style="font-family: var(--theme-font-title); color: var(--theme-text);"
                    >
                        HORARIOS
                    </h3>
                    <div class="grid grid-cols-2 gap-4 max-w-md">
                        <div>
                            <p class="font-bold text-gabis-red">MAÑANAS</p>
                            <p>Todos los días</p>
                            <p>7:00 AM - 4:00 PM</p>
                        </div>
                        <div>
                            <p class="font-bold text-gabis-orange">NOCHES</p>
                            <p>Todos los días</p>
                            <p>4:00 PM - 10:00 PM</p>
                        </div>
                    </div>
                </div>

                <div class="pt-4">
                    <a
                        href="https://www.google.com/maps/search/?api=1&query=Gabis+Birria+y+Alitas+Ecatepec"
                        target="_blank"
                        rel="noreferrer"
                        class="inline-block bg-black text-white text-xl px-8 py-3 rounded-full hover:bg-gabis-yellow transition-colors transition-all duration-500"
                        style="background-color: var(--theme-text); color: var(--theme-bg); font-family: var(--theme-font-title);"
                    >
                        VER EN GOOGLE MAPS
                    </a>
                </div>
            </div>
        </div>

        <!-- Google Maps Embed -->
        <div
            class="h-[500px] bg-neutral-200 rounded-3xl overflow-hidden relative shadow-lg transition-colors duration-500"
            style="background-color: var(--theme-card-bg);"
        >
            <iframe
                src={mapSrc}
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
            >
            </iframe>
        </div>
    </div>
</section>
