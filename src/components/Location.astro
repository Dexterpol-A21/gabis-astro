---
---

<section id="location" class="py-16 bg-gabis-black text-white relative overflow-hidden">
  <div class="container mx-auto px-4 flex flex-col md:flex-row gap-8 items-center z-10 relative">
    
    <!-- Info Column -->
    <div class="w-full md:w-1/2 p-4">
      <h2 class="font-stardom text-4xl mb-6 text-gabis-yellow">Visítanos</h2>
      
      <div class="space-y-6">
        <!-- Address -->
        <div class="flex items-start gap-4">
          <div class="bg-gabis-yellow p-3 rounded-full shrink-0 text-gabis-black">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-tanker text-xl font-bold mb-1">Dirección</h3>
            <p class="font-satoshi text-gray-300">
              Calle Principal #123, Col. Centro<br>
              Tu Ciudad, Estado, CP 12345
            </p>
          </div>
        </div>

        <!-- Schedule -->
        <div class="flex items-start gap-4">
           <div class="bg-gabis-yellow p-3 rounded-full shrink-0 text-gabis-black">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-tanker text-xl font-bold mb-1">Horarios</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="bg-white/10 p-3 rounded-lg border-l-4 border-gabis-orange">
                <p class="text-gabis-orange font-tanker font-bold text-sm">☀️ MAÑANAS (Birria)</p>
                <p class="font-satoshi text-sm">Todos los días: 7:00 AM - 4:00 PM</p>
              </div>
              <div class="bg-white/10 p-3 rounded-lg border-l-4 border-gabis-red">
                <p class="text-gabis-red font-tanker font-bold text-sm">🌙 TARDES (Alitas)</p>
                <p class="font-satoshi text-sm">Todos los días: 4:00 PM - 10:00 PM</p>
              </div>
            </div>
          </div>
        </div>

         <!-- Contact -->
         <div class="flex items-start gap-4">
          <div class="bg-gabis-yellow p-3 rounded-full shrink-0 text-gabis-black">
           <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
           </svg>
         </div>
         <div>
           <h3 class="font-tanker text-xl font-bold mb-1">Pedidos</h3>
           <p class="font-satoshi text-gray-300 hover:text-gabis-yellow transition-colors cursor-pointer">
             +52 (123) 456 7890
           </p>
         </div>
       </div>
      </div>
    </div>

    <!-- Map Column -->
    <div class="w-full md:w-1/2 h-96 rounded-xl overflow-hidden shadow-2xl border-4 border-gabis-yellow/20">
      <iframe 
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15050.485123927652!2d-99.133209!3d19.432608!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85ce0026db097507%3A0x540e107626608412!2sZ%C3%B3calo!5e0!3m2!1ses-419!2smx!4v1650000000000!5m2!1ses-419!2smx" 
        width="100%" 
        height="100%" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
    </div>
  </div>
</section>
