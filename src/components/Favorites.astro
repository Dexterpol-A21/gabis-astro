---
const favorites = [
  {
    title: "Birria Estilo Jalisco",
    description: "Nuestra especialidad matutina. Carne suave, consomé rico y tortillas hechas a mano.",
    image: "/images/menuFrente.jpeg", // Placeholder for Birria
    tag: "Mañanas",
    color: "bg-gabis-orange"
  },
  {
    title: "Hamburguesas al Carbón",
    description: "Carne jugosa, queso derretido y vegetales frescos. El clásico que nunca falla.",
    image: "/images/hamburguesasPrincipal.jpg",
    tag: "Tardes",
    color: "bg-gabis-red"
  },
  {
    title: "Alitas & Boneless",
    description: "Crujientes y bañadas en tu salsa favorita: BBQ, Buffalo, Mango Habanero y más.",
    image: "/images/alitasPrincipal.jpg",
    tag: "Tardes",
    color: "bg-gabis-red"
  }
];
---

<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="font-stardom text-4xl md:text-5xl text-gabis-black mb-4">Los Favoritos de la Casa</h2>
      <p class="font-satoshi text-gray-600 max-w-2xl mx-auto">
        Estos son los platillos que nos han hecho famosos. Ya sea para despertar o para cerrar el día, aquí está lo mejor de Gabis.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {favorites.map((item) => (
        <div class="group relative rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 bg-white">
          <div class="h-64 overflow-hidden relative">
            <span class={`absolute top-4 right-4 text-white text-xs font-bold px-3 py-1 rounded-full z-10 ${item.color}`}>
              {item.tag}
            </span>
            <img src={item.image} alt={item.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>
          
          <div class="p-6">
            <h3 class="font-tanker text-2xl font-bold text-gabis-black mb-2">{item.title}</h3>
            <p class="font-satoshi text-gray-600 mb-4 text-sm">{item.description}</p>
            <button class={`w-full py-2 rounded-lg text-white font-tanker font-bold transition-colors ${item.color} brightness-90 hover:brightness-110`}>
              ¡Se me antoja!
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
