---
const links = [
  { text: "Inicio", href: "#" },
  { text: "Mañanas", href: "#birria" },
  { text: "Tardes", href: "#afternoon" },
  { text: "Ubicación", href: "#location" },
];
---

<nav class="fixed w-full z-50 transition-all duration-300 bg-gabis-black/95 text-white shadow-md backdrop-blur-sm" id="navbar">
  <div class="container mx-auto px-4 py-3 flex justify-between items-center">
    <a href="#" class="font-stardom text-2xl text-gabis-yellow hover:text-white transition-colors">
      Gabis
    </a>

    <!-- Desktop Menu -->
    <ul class="hidden md:flex space-x-8 font-tanker font-bold text-lg">
      {links.map(link => (
        <li>
          <a href={link.href} class="hover:text-gabis-yellow transition-colors relative after:content-[''] after:absolute after:w-0 after:h-0.5 after:bg-gabis-yellow after:left-0 after:-bottom-1 after:transition-all hover:after:w-full">
            {link.text}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile Menu Button (Hamburger) -->
    <button id="mobile-menu-btn" class="md:hidden text-gabis-yellow focus:outline-none">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden md:hidden bg-gabis-black border-t border-gabis-yellow/30">
    <ul class="flex flex-col p-4 space-y-4 font-tanker font-bold text-center">
      {links.map(link => (
        <li>
          <a href={link.href} class="block hover:text-gabis-yellow py-2" onclick="document.getElementById('mobile-menu').classList.add('hidden')">
            {link.text}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
