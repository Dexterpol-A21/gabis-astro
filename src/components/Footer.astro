---
import MetallicSignature from './MetallicSignature.jsx';
const currentYear = new Date().getFullYear();
---

<footer
    class="pt-20 pb-24 md:pb-10 border-t transition-colors duration-500"
    style="background-color: #101010; color: #ffffff; border-color: var(--theme-border);"
>
    <div class="max-w-7xl mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12 md:mb-16">
            <!-- Brand -->
            <div class="col-span-1">
                <div class="flex items-center gap-3 mb-6">
                    <div
                        class="w-10 h-10 bg-white transition-colors duration-500"
                        style="-webkit-mask-image: url(/images/gabisNoF.svg); -webkit-mask-size: contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center; mask-image: url(/images/gabisNoF.svg); mask-size: contain; mask-repeat: no-repeat; mask-position: center; background-color: var(--theme-accent);"
                    >
                    </div>
                    <span
                        class="text-5xl leading-none transition-all duration-500"
                        style="font-family: var(--theme-font-title); color: var(--theme-accent);"
                        >GABIS</span
                    >
                </div>
                <p
                    class="font-satoshi text-gray-400 text-sm leading-relaxed mb-6 opacity-90 max-w-sm"
                >
                    Dos experiencias, un solo lugar. <br />
                    Birria por la mañana, Cenas & Snacks por la noche.
                </p>
                <div class="font-satoshi text-gray-500 text-xs uppercase tracking-wide">
                    <p class="font-bold text-gray-300 mb-1">Ubicación</p>
                    <p>Ecatepec / Coacalco</p>
                    <p>Guadalupe Victoria, 55010</p>
                </div>
            </div>

            <!-- Links -->
            <div class="md:pl-10">
                <h4
                    class="text-lg mb-6 tracking-wide transition-all duration-500 font-bold opacity-80"
                    style="font-family: var(--theme-font-title); color: #fff;"
                >
                    NAVEGACIÓN
                </h4>
                <ul class="space-y-3 font-satoshi text-gray-400 text-sm">
                    <li>
                        <a href="/" class="hover:text-white transition-colors block"
                            >Inicio</a
                        >
                    </li>
                    <li>
                        <a
                            href="/#menu-bento"
                            class="hover:text-white transition-colors block"
                            >Menú</a
                        >
                    </li>
                    <li>
                        <a
                            href="/eventos"
                            class="hover:text-white transition-colors block"
                            >Eventos</a
                        >
                    </li>
                    <li>
                        <a
                            href="/ubicacion"
                            class="hover:text-white transition-colors block"
                            >Ubicación</a
                        >
                    </li>
                    <li>
                        <a
                            href="/faq"
                            class="hover:text-white transition-colors block"
                            >FAQ</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Contact -->
            <div>
                <h4
                    class="text-lg mb-6 tracking-wide transition-all duration-500 font-bold opacity-80"
                    style="font-family: var(--theme-font-title); color: #fff;"
                >
                    CONTACTO
                </h4>
                <div class="space-y-4">
                    <!-- WhatsApp -->
                    <a
                        href="https://wa.me/525660299028"
                        class="group flex items-start gap-4 hover:opacity-100 opacity-80 transition-all"
                    >
                        <div
                            class="w-10 h-10 flex-shrink-0 flex items-center justify-center rounded-lg bg-[#25D366]/10 text-[#25D366] group-hover:bg-[#25D366] group-hover:text-white transition-colors"
                        >
                            <svg
                                class="w-5 h-5"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.232-.298.347-.497.115-.198.058-.372-.029-.545-.087-.174-.793-1.912-1.087-2.622-.284-.685-.572-.591-.786-.603-.207-.011-.444-.014-.68-.014-.237 0-.622.089-.947.436-.325.347-1.24 1.212-1.24 2.956 0 1.744 1.271 3.429 1.446 3.666.175.237 2.498 3.816 6.051 5.348 3.553 1.533 3.553 1.023 4.195.952.641-.072 2.059-.841 2.353-1.652.295-.812.295-1.509.207-1.658-.088-.149-.325-.237-.622-.385zM12 2C6.48 2 2 6.48 2 12c0 1.82.48 3.53 1.31 5.02L2.32 22l5.06-1.31C8.82 21.35 10.37 21.9 12 21.9c5.52 0 10-4.48 10-10S17.52 2 12 2zm0 18.2c-1.48 0-2.9-.39-4.13-1.07l-.3-.16-3.07.8.82-2.99-.16-.32A8.17 8.17 0 0 1 3.8 12c0-4.52 3.67-8.2 8.2-8.2 4.52 0 8.2 3.67 8.2 8.2 0 4.52-3.68 8.2-8.2 8.2z"
                                ></path></svg
                            >
                        </div>
                        <div class="pt-1">
                            <span class="block text-white text-base font-medium leading-tight"
                                >WhatsApp</span
                            >
                            <span
                                class="text-sm text-gray-500 group-hover:text-gray-400 transition-colors"
                                >56 6029 9028</span
                            >
                        </div>
                    </a>

                    <!-- Email -->
                    <a
                        href="mailto:contacto@gabis.com.mx"
                        class="group flex items-start gap-4 hover:opacity-100 opacity-80 transition-all"
                    >
                        <div
                            class="w-10 h-10 flex-shrink-0 flex items-center justify-center rounded-lg bg-[#3b82f6]/10 text-[#3b82f6] group-hover:bg-[#3b82f6] group-hover:text-white transition-colors"
                        >
                            <svg
                                class="w-5 h-5"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                                ></path></svg
                            >
                        </div>
                        <div class="pt-1">
                            <span class="block text-white text-base font-medium leading-tight"
                                >Correo</span
                            >
                            <span
                                class="text-sm text-gray-500 group-hover:text-gray-400 transition-colors"
                                >contacto@gabis.com.mx</span
                            >
                        </div>
                    </a>
                </div>
            </div>
        </div>

        <div
            class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center text-sm md:text-xs text-gray-500 md:text-gray-600 font-satoshi gap-6 md:gap-4"
        >
            {/* Izquierda: Firma */}
            <div class="w-full md:w-1/3 flex justify-center md:justify-start order-1 md:order-1">
                <div class="transform scale-90 hover:scale-100 opacity-80 hover:opacity-100 transition-all duration-300">
                    <MetallicSignature client:visible />
                </div>
            </div>

            {/* Centro: Copyright */}
            <div class="w-full md:w-1/3 text-center order-2 md:order-2">
                <p>&copy; {currentYear} Gabis. Todos los derechos reservados.</p>
            </div>

            {/* Derecha: Políticas */}
            <div class="w-full md:w-1/3 flex justify-center md:justify-end gap-6 md:gap-4 order-3 md:order-3">
                <a href="/aviso-de-privacidad" class="hover:text-gray-300 transition-colors">Aviso de Privacidad</a>
                <a href="/terminos-y-condiciones" class="hover:text-gray-300 transition-colors"
                    >Términos y Condiciones</a
                >
            </div>
        </div>
    </div>
</footer>
