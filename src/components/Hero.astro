---
---
<section class="relative w-full min-h-screen flex items-center justify-center overflow-hidden bg-stone-100">
  
  <!-- Background Texture: Abstract Stone/Marble Effect -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-[#f5f5f0] opacity-100"></div>
    <!-- Subtle noise/grain could be added here via CSS url() if available, using radial gradient for lighting focus -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_transparent_0%,_#d6d3d1_100%)] opacity-40"></div>
  </div>

  <!-- LEF SIDE: Tradition / Morning Frame -->
  <!-- Placeholder note: When you have the transparent PNG of the birria/consome, place it here replacing the div/img below -->
  <div class="absolute left-0 top-0 bottom-0 w-1/3 z-10 hidden md:flex items-center justify-start pointer-events-none translate-x-[-10%] hover:translate-x-0 transition-transform duration-700">
    <!-- Using existing image pushed to the side to simulate the frame concept -->
    <img 
      src="/images/menuFrente.jpeg" 
      alt="Marco Birria" 
      class="h-[120vh] max-w-none object-cover opacity-90 mask-image-gradient-right drop-shadow-2xl"
      style="-webkit-mask-image: linear-gradient(to right, black 50%, transparent 100%); mask-image: linear-gradient(to right, black 50%, transparent 100%);"
    />
    <!-- Concept Label (Helper for dev) -->
    <div class="absolute left-10 top-1/2 -rotate-90 origin-center text-gabis-orange/20 font-bold text-6xl tracking-widest whitespace-nowrap">
      TRADICIÓN
    </div>
  </div>

  <!-- RIGHT SIDE: Craving / Afternoon Frame -->
   <!-- Placeholder note: When you have the transparent PNG of the burger/wings, place it here replacing the div/img below -->
  <div class="absolute right-0 top-0 bottom-0 w-1/3 z-10 hidden md:flex items-center justify-end pointer-events-none translate-x-[10%] hover:translate-x-0 transition-transform duration-700">
    <!-- Using existing image pushed to the side to simulate the frame concept -->
    <img 
      src="/images/hamburguesasPrincipal.jpg" 
      alt="Marco Antojo" 
      class="h-[120vh] max-w-none object-cover opacity-90 mask-image-gradient-left drop-shadow-2xl"
      style="-webkit-mask-image: linear-gradient(to left, black 50%, transparent 100%); mask-image: linear-gradient(to left, black 50%, transparent 100%);"
    />
     <!-- Concept Label (Helper for dev) -->
     <div class="absolute right-10 top-1/2 rotate-90 origin-center text-gabis-red/20 font-bold text-6xl tracking-widest whitespace-nowrap">
        ANTOJO
      </div>
  </div>

  <!-- CENTER: The Message (Negative Space) -->
  <div class="relative z-20 text-center max-w-4xl px-4 flex flex-col items-center">
    
    <!-- Floating Logo -->
    <div class="mb-6 transform hover:scale-105 transition-transform duration-300">
      <img src="/images/logoNoFondo (1).png" alt="Gabis Logo" class="w-40 md:w-64 drop-shadow-2xl animate-float" />
    </div>

    <!-- Main Copy -->
    <h1 class="font-stardom text-5xl md:text-7xl text-gabis-black mb-2 drop-shadow-sm leading-tight">
      El Sabor que Une
    </h1>
    
    <div class="flex items-center justify-center gap-4 text-sm md:text-xl font-tanker font-bold tracking-wide mb-8">
      <span class="text-gabis-orange uppercase">Mañanas de Tradición</span>
      <span class="w-2 h-2 rounded-full bg-stone-300"></span>
      <span class="text-gabis-red uppercase">Tardes de Amigos</span>
    </div>

    <!-- Dual Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 w-full justify-center">
      <a href="#birria" class="group relative px-8 py-4 bg-gabis-orange text-white font-tanker font-bold rounded-full overflow-hidden shadow-lg hover:shadow-xl transition-all">
        <span class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></span>
        <span class="relative flex items-center gap-2">
          <span>☀️</span> Ir a Desayunos
        </span>
      </a>
      
      <a href="#afternoon" class="group relative px-8 py-4 bg-white text-gabis-red border-2 border-gabis-red font-tanker font-bold rounded-full overflow-hidden shadow-lg hover:shadow-xl transition-all">
        <span class="absolute inset-0 bg-gabis-red translate-y-full group-hover:translate-y-0 transition-transform duration-300"></span>
        <span class="relative group-hover:text-white flex items-center gap-2">
          <span>🌙</span> Ir a Comidas
        </span>
      </a>
    </div>

  </div>

  <!-- Mobile Background Fallback (Since frames are hidden on mobile) -->
  <div class="absolute inset-0 md:hidden z-0">
     <!-- Top Half Tint -->
     <div class="absolute top-0 left-0 w-full h-1/2 bg-gradient-to-b from-gabis-orange/10 to-transparent"></div>
     <!-- Bottom Half Tint -->
     <div class="absolute bottom-0 left-0 w-full h-1/2 bg-gradient-to-t from-gabis-red/10 to-transparent"></div>
  </div>

</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
</style>
