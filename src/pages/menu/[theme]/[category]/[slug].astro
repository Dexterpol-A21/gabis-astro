---
import Layout from "../../../../layouts/Layout.astro";
import { menuData } from "../../../../data/menu.js";
import { Image, getImage } from "astro:assets";

export async function getStaticPaths() {
    const paths = [];

    // Helper to slugify text
    const slugify = (text) =>
        text
            .toLowerCase()
            .replace(/[^\w\s-]/g, "")
            .replace(/\s+/g, "-");

    // Morning Items
    menuData.morning.categories.forEach((cat) => {
        cat.items.forEach((item) => {
            paths.push({
                params: {
                    theme: "manana",
                    category: slugify(cat.name),
                    slug: slugify(item.name),
                },
                props: { item, category: cat.name, theme: "morning" },
            });
        });
    });

    // Night Items
    menuData.night.categories.forEach((cat) => {
        cat.items.forEach((item) => {
            paths.push({
                params: {
                    theme: "noche",
                    category: slugify(cat.name),
                    slug: slugify(item.name),
                },
                props: { item, category: cat.name, theme: "night" },
            });
        });
    });

    return paths;
}

const { item, category, theme } = Astro.props;
const isNight = theme === "night";
const slugify = (text) =>
    text
        .toLowerCase()
        .replace(/[^\w\s-]/g, "")
        .replace(/\s+/g, "-");

// Theme Colors/Fonts
const themeColor = isNight ? "var(--color-noche)" : "var(--color-birria)";
const themeFont = isNight ? "var(--font-noche)" : "var(--font-manana)";
const textColor = isNight ? "#ffffff" : "var(--color-black)";
const bgColor = isNight ? "#141414" : "var(--color-bg)";

// Construct WhatsApp Message
const waNumber = "525660299028";
const waMessage = `Hola Gabis, quisiera pedir: ${item.name} (${item.price})`;
const waLink = `https://wa.me/${waNumber}?text=${encodeURIComponent(waMessage)}`;

// --- IMAGE MAPPING (Shared with MenuBento) ---
const imageMap = {
    // MORNING
    "plato de birria": "/images/manana/platoBirriaNoF.png",
    birriamen: "/images/manana/birriamenNoF.png",
    "paquete familiar": "/images/manana/packBirria1NoF.png",
    "tacos de birria": "/images/manana/ordentacobirriaNoF.png",
    quesabirria: "/images/manana/quesabirriasNoF.png",
    molletes: "/images/manana/molletesTodosNoF.png",
    sincronizada: "/images/manana/sinronizada1NoF.png",
    "hotcakes tradicionales": "/images/manana/hotcakessencillosNoF.png",
    "hotcakes especiales": "/images/manana/hotcakesEspecialesNoF.png",
    "latte macchiato": "/images/manana/latteNoF.png",
    "americano doble": "/images/manana/americanodobleNoF.png",
    cappuccino: "/images/manana/capuccinoNoF.png",
    "café americano": "/images/manana/cafeNoF.png",
    espresso: "/images/manana/dobleexpresoNoF.png",
    nescafé: "/images/manana/cafeNoF.png",
    "combo nescafé + pan": "/images/manana/cafeminipanNoF.png",
    "mini pan": "/images/manana/panNoF.png",
    "flan casero": "/images/noche/flanNoF.png",
    refrescos: "/images/noche/cocaNoF.png",

    // NIGHT
    // Burgers
    sencilla: "/images/noche/hamburguesasencilaNoF.png",
    bacon: "/images/noche/hamburguesaNoF.png",
    hawaiana: "/images/noche/hamburguesahawaianaNoF.png",
    especial: "/images/noche/hamburguesaespecialNoF.png",
    sliders: "/images/noche/slidersNoF.png",
    // Wings
    "orden de alitas": "/images/noche/alitasNoF.png",
    alitas: "/images/noche/alitasNoF.png", // Fallback
    boneless: "/images/noche/bonelessNoF.png",
    // Snacks
    "papas bacon": "/images/noche/papasBaconNoF.png",
    "orden papas francesas": "/images/noche/papa1NoF.png",
    salchipulpos: "/images/noche/salchipulposNoF.png",
    // Hot Dogs
    "jumbo clásico": "/images/noche/hotdogsencilloNoF.png",
    "jumbo bacon": "/images/noche/hotdogbaconNoF.png",
    // Dessert & Drinks
    "flan napolitano": "/images/noche/flanNoF.png",
    // Refrescos maps to existing 'refrescos' key
};

// --- IMAGE OPTIMIZATION ---
const imagesGlob = import.meta.glob('../../../../../src/assets/images/**/*.{png,jpg,jpeg,svg}', { import: "default", eager: true });

const getImagePath = (itemName, theme) => {
    let path = item.image || null;

    if (!path) {
        const key = itemName.toLowerCase();
        // 1. Try exact match
        if (imageMap[key]) {
            path = imageMap[key];
        } else {
             // 2. Try partial match
             const found = Object.keys(imageMap).find(k => key.includes(k) || k.includes(key));
             if (found) {
                path = imageMap[found];
            } else {
                 // 3. Fallback
                 path = theme === "morning" ? "/images/manana/consomeNoF.png" : "/images/noche/hamburguesaNoF.png";
            }
        }
    }

    // Try to find the imported image module for optimization
    if (path) {
        // Path is something like "/images/manana/platoBirriaNoF.png"
        // import.meta.glob keys are relative to this file, OR absolute if we check carefully.
        // But glob above uses relative path ../../../../../src/assets/images/
        // Actually, importing relative to src/assets is safer.

        const filename = path.split('/').pop(); // platoBirriaNoF.png
        
        // Find in glob entries
        const foundEntry = Object.entries(imagesGlob).find(([k, v]) => k.includes(filename));
        if (foundEntry) {
             return foundEntry[1]; // Return the module (ImageMetadata)
        }
    }
    
    return path; // Fallback to string if not found in assets
};

const imageAsset = getImagePath(item.name, theme);
// If it's a string, it's a public path. If object, it's ImageMetadata.
const isOptimized = typeof imageAsset !== 'string';

// --- SEO DESCRIPTION GENERATOR ---
// Honest, informative descriptions without marketing fluff
const getSEODescription = (item, category, isNight) => {
    const baseDesc = item.description || "";
    const name = item.name;
    const cat = category.toLowerCase();

    let details = "";

    if (!isNight) {
        // Morning - Focus on preparation and ingredients
        if (cat.includes("birria") || cat.includes("caldos")) {
            details = `Preparado con especias tradicionales y carne de res cocida lentamente. Se sirve con cilantro, cebolla picada y tortillas de maíz. Disponible en horario de mañana (7:00 - 16:00).`;
        } else if (cat.includes("quesabirria") || cat.includes("tacos")) {
            details = `La tortilla se dora en el comal con queso y carne de birria. Cada orden incluye consomé para acompañar. Servido caliente al momento.`;
        } else if (cat.includes("almuerzo") || cat.includes("antojo")) {
            details = `Preparado al momento con ingredientes frescos del día. Opción popular para media mañana. Se puede personalizar según preferencia.`;
        } else if (cat.includes("café") || cat.includes("cafetería")) {
            if (name.toLowerCase().includes("hotcake")) {
                details = `Tres piezas esponjosas servidas calientes. Acompañadas de mantequilla y miel. Opción de agregar toppings adicionales.`;
            } else {
                details = `Bebida caliente preparada al momento. Opción de café de grano o soluble según disponibilidad. Se puede pedir para llevar.`;
            }
        } else {
            details = `Disponible en horario de mañana. Preparado al momento. Consulta ingredientes adicionales en el establecimiento.`;
        }
    } else {
        // Night - Focus on portion sizes and what's included
        if (cat.includes("hamburguesa") || cat.includes("burger")) {
            details = `Carne de res (130g) cocinada en plancha. Servida en pan con lechuga, jitomate, cebolla y aderezos. Todas las hamburguesas incluyen papas a la francesa.`;
        } else if (cat.includes("alitas") || cat.includes("boneless")) {
            details = `6 piezas por orden. Servidas con papas a la francesa. Elige tu salsa: BBQ, Original, Búfalo, Habanero Mango, o Negra Especial. Servidas calientes.`;
        } else if (cat.includes("snack") || cat.includes("papas")) {
            details = `Porción individual. Servido caliente con los aderezos indicados. Opción para compartir o como acompañamiento.`;
        } else if (cat.includes("jocho") || cat.includes("hot dog")) {
            details = `Salchicha de pavo tamaño jumbo. Servida en pan con vegetales frescos y aderezos al gusto. Porción individual.`;
        } else {
            details = `Disponible en horario nocturno (16:00 - 22:00). Preparado al momento. Ideal para llevar o consumir en el local.`;
        }
    }

    return baseDesc ? `${baseDesc} ${details}` : details;
};

const expandedDescription = getSEODescription(item, category, isNight);
const googleMapsLink = "https://maps.app.goo.gl/tuLinkAqui"; // Replace with actual link if known, otherwise generic or query
---

<Layout title={`${item.name} | Gabis`} hideNavMenu={true}>
    <div
        class="h-screen w-full overflow-hidden transition-colors duration-500 flex flex-col pt-6 pb-6 px-4 md:px-8"
        style={`background-color: ${bgColor}; color: ${textColor}`}
    >
        <!-- SIMPLE HEADER -->
        <header
            class="w-full max-w-6xl mx-auto mb-4 md:mb-8 flex justify-between items-center flex-none"
        >
            <a
                href="/"
                class="flex items-center gap-3 hover:opacity-80 transition-opacity"
            >
                <div
                    style={`width: 32px; height: 32px; background-color: ${themeColor}; mask-image: url(/images/gabisNoF.svg); -webkit-mask-image: url(/images/gabisNoF.svg); mask-size: contain; -webkit-mask-size: contain; mask-repeat: no-repeat; -webkit-mask-repeat: no-repeat; mask-position: center; -webkit-mask-position: center;`}
                >
                </div>
                <span
                    style={`font-family: ${themeFont}; font-size: 24px; color: ${themeColor}; letter-spacing: 0.05em;`}
                    >GABIS</span
                >
            </a>
            <a
                href="/"
                class="text-sm opacity-60 hover:opacity-100 transition-opacity flex items-center gap-2 font-medium"
                style={`color: ${textColor}`}
            >
                <span>←</span> Volver
            </a>
        </header>

        <div
            class="flex-1 w-full max-w-6xl mx-auto grid md:grid-cols-2 gap-6 md:gap-12 items-center overflow-hidden"
        >
            <!-- HERO IMAGE -->
            <div
                class="relative w-full h-full max-h-[40vh] md:max-h-full flex items-center justify-center p-4"
            >
                <div
                    class="aspect-square w-auto h-full max-h-full bg-white/5 rounded-3xl overflow-hidden shadow-2xl relative border border-white/10 flex items-center justify-center"
                >
                    {isOptimized ? (
                        <Image
                            src={imageAsset}
                            class="w-full h-full object-contain p-8 hover:scale-105 transition-transform duration-500"
                            alt={item.name}
                            format="avif"
                            quality={80}
                            transition:name={`image-${slugify(item.name)}`}
                        />
                    ) : (
                        <img
                            src={imageAsset}
                            onerror="this.style.display='none'"
                            class="w-full h-full object-contain p-8 hover:scale-105 transition-transform duration-500"
                            alt={item.name}
                            transition:name={`image-${slugify(item.name)}`}
                        />
                    )}
                </div>
            </div>

            <!-- DETAILS -->
            <div
                class="flex flex-col justify-center h-full overflow-y-auto pr-2"
            >
                <div>
                    <span
                        class="inline-block px-4 py-1.5 rounded-full text-xs font-black tracking-widest uppercase mb-4 shadow-sm transform -rotate-1"
                        style="background-color: #FDDA04; color: #141414;"
                    >
                        ✦ {category}
                    </span>
                    <h1
                        class="text-4xl md:text-7xl leading-none mb-4"
                        style={`font-family: ${themeFont}; color: ${themeColor}`}
                    >
                        {item.name}
                    </h1>
                    <p class="text-2xl md:text-3xl font-light opacity-90">
                        {item.price}
                    </p>
                </div>

                <!-- Expanded SEO Description -->
                <p
                    class="text-base md:text-lg opacity-70 leading-relaxed max-w-md mt-6 mb-8"
                >
                    {expandedDescription}
                </p>

                <!-- DUAL CTAS -->
                <div
                    class="pt-6 border-t border-white/10 flex flex-col sm:flex-row gap-3 md:gap-4 mt-auto md:mt-0"
                >
                    <!-- 1. Pedir para Pickup (WhatsApp) -->
                    <a
                        href={waLink}
                        target="_blank"
                        class="flex-1 inline-flex justify-center items-center gap-3 px-6 py-3 md:px-8 md:py-4 rounded-full text-white font-bold tracking-wide hover:scale-105 transition-transform shadow-lg hover:shadow-xl text-sm md:text-base"
                        style={`background-color: #25D366`}
                    >
                        <svg
                            class="w-5 h-5 md:w-6 md:h-6"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
                            ></path></svg
                        >
                        Pedir para Pickup
                    </a>

                    <!-- 2. Quiero ir (Maps) -->
                    <a
                        href="https://www.google.com/maps/search/?api=1&query=Gabis+Calle+La+Fama+14+Tlalpan+CDMX"
                        target="_blank"
                        class="flex-1 inline-flex justify-center items-center gap-3 px-6 py-3 md:px-8 md:py-4 rounded-full font-bold tracking-wide hover:scale-105 transition-transform border-2 hover:bg-white hover:text-black text-sm md:text-base"
                        style={`border-color: ${themeColor}; color: ${themeColor}`}
                    >
                        <svg
                            class="w-5 h-5 md:w-6 md:h-6"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                            ></path><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                            ></path></svg
                        >
                        Quiero ir
                    </a>
                </div>
            </div>
        </div>
    </div>
</Layout>
