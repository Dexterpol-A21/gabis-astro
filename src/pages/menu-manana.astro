---
import { PaperMenuManana } from "../components/PaperMenuManana.jsx";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Gabis | Menú de Mañana">
    <main class="bg-white min-h-screen paper-menu-page">
        {/* Paper Menu Component - Has its own floating navigation */}
        <PaperMenuManana client:load />
    </main>
</Layout>

<style is:global>
    /* Hide ALL site navigation on paper menu pages */
    .staggered-menu-header,
    .staggered-menu-nav,
    .staggered-menu-wrapper {
        display: none !important;
    }

    /* CRITICAL: Hide mobile bottom nav on paper menu pages */
    body:has(.paper-menu-page) .fixed.bottom-0 {
        display: none !important;
    }

    /* BUTTON SIZING FOR MOBILE - USING NEW CLASSES */
    @media (max-width: 640px) {
        /* Top Switch Button - COMPACT/SMALLER */
        .paper-menu-top-nav {
            top: 10px !important;
            padding: 4px 12px !important;
            line-height: 1 !important;
        }
        .paper-menu-top-nav a {
            font-size: 11px !important;
            gap: 4px !important;
            display: flex !important;
            align-items: center !important;
        }
        .paper-menu-top-nav span[style*="fontSize: '18px'"] {
            font-size: 14px !important;
            line-height: 1 !important;
        }

        /* Bottom Control Buttons Container - LARGER/NORMAL */
        .paper-menu-bottom-controls {
            bottom: 20px !important;
            padding: 8px 16px !important; /* Back to comfortable padding */
            gap: 12px !important;
            width: auto !important;
            border-radius: 30px !important;
            min-height: auto !important;
        }

        /* Buttons inside bottom controls */
        .paper-menu-bottom-controls button {
            padding: 8px 16px !important; /* Proper touch target */
            font-size: 14px !important; /* Readable text */
            gap: 8px !important;
            min-height: 40px !important; /* Standard height */
            height: auto !important;
            display: flex !important;
            align-items: center !important;
        }

        /* Adjust specific text/icons inside buttons */
        .paper-menu-bottom-controls button span[style*="fontSize: '20px'"] {
            font-size: 18px !important;
            line-height: 1 !important;
        }
        .paper-menu-bottom-controls button svg {
            width: 16px !important; /* Normal icon size */
            height: 16px !important;
            margin-bottom: 2px !important;
        }

        /* Divider line */
        .paper-menu-bottom-controls > div[style*="width: '1px'"] {
            height: 24px !important;
        }
    }

    @media print {
        html,
        body {
            background: white !important;
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            height: auto !important;
        }
        main {
            background: white !important;
            padding: 0 !important;
            margin: 0 !important;
            position: static !important;
            width: 100% !important;
        }
        /* Hide EVERYTHING that shouldn't print */
        header,
        nav,
        .staggered-menu-header,
        .staggered-menu-nav,
        .staggered-menu-wrapper,
        .MainHeader,
        .custom-main-header,
        [class*="Header"],
        [class*="header"],
        .no-print,
        .fixed,
        [style*="position: fixed"],
        [style*="position:fixed"] {
            display: none !important;
            visibility: hidden !important;
            height: 0 !important;
            width: 0 !important;
            overflow: hidden !important;
            position: absolute !important;
            top: -9999px !important;
            left: -9999px !important;
        }

        .paper-menu-container {
            display: block !important;
            visibility: visible !important;
            position: absolute !important;
            top: 0 !important;
            left: 0 !important;
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
        }

        .paper-menu-container > .page:first-of-type {
            margin-top: 0 !important;
            padding-top: 0 !important;
        }
    }
</style>
