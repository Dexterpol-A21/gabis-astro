---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import { getImage } from "astro:assets";

// Import images
import imgBirthdayM from "../assets/images/manana/nuestrahistoriabirria.png";
import imgBirthdayN from "../assets/images/noche/nosotroshamburguesa.png";
import imgOfficeM from "../assets/images/manana/platoBirriaNoF.png";
import imgOfficeN from "../assets/images/noche/alitasNoF.png";
import imgFullM from "../assets/images/manana/nuestrahistoriaquesabirria.png";
import imgFullN from "../assets/images/noche/nosotrosalitas.png";

const optimizedImages = await Promise.all([
    getImage({ src: imgBirthdayM, format: 'avif', quality: 80 }),
    getImage({ src: imgBirthdayN, format: 'avif', quality: 80 }),
    getImage({ src: imgOfficeM, format: 'avif', quality: 80 }),
    getImage({ src: imgOfficeN, format: 'avif', quality: 80 }),
    getImage({ src: imgFullM, format: 'avif', quality: 80 }),
    getImage({ src: imgFullN, format: 'avif', quality: 80 }),
]);

const [
    bgBirthdayM, 
    bgBirthdayN, 
    bgOfficeM, 
    bgOfficeN, 
    bgFullM, 
    bgFullN
] = optimizedImages;
---

<Layout title="Eventos & Celebraciones | Gabis" forceHeaderVisible={true}>
    <div
        class="min-h-screen pb-32 md:pb-0 transition-colors duration-500 bg-[var(--theme-bg)] text-[var(--theme-text)] font-satoshi selection:bg-[var(--theme-accent)] selection:text-white"
    >
        <!-- HERO HEADLINE -->
        <div class="pt-4 md:pt-24 pb-16 px-1 md:px-4 text-center">
            <h1
                class="font-[var(--theme-font-title)] text-7xl md:text-9xl mb-6 leading-none tracking-tight text-[var(--theme-accent)] drop-shadow-sm transition-all duration-500"
            >
                THE<br />GATHERING
            </h1>
            <p
                class="text-2xl md:text-3xl opacity-90 max-w-2xl mx-auto"
                style="font-family: var(--theme-font-title);"
            >
                Donde el hambre se junta con la fiesta. <br />
                <span class="text-[var(--theme-accent)]"
                    >Reserva tu mesa o evento completo.</span
                >
            </p>
        </div>

        <!-- EVENT TYPES GRID -->
        <div class="max-w-7xl mx-auto px-1 md:px-4 grid md:grid-cols-3 gap-8 mb-16">
            <!-- BIRTHDAYS -->
            <div
                class="group relative aspect-[3/4] rounded-3xl overflow-hidden border transition-colors duration-300 bg-[var(--theme-card-bg)] border-[var(--theme-border)] hover:border-[var(--theme-accent)] shadow-lg hover:shadow-xl"
            >
                <div
                    class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent z-10 pointer-events-none"
                >
                </div>
                <!-- Image - Dynamic based on theme -->
                <div
                    class="absolute inset-0 bg-cover bg-center opacity-100 group-hover:scale-105 transition-transform duration-700 theme-bg-image"
                    style={`--bg-light: url('${bgBirthdayM.src}'); --bg-dark: url('${bgBirthdayN.src}');`}
                >
                </div>

                <div class="absolute bottom-0 left-0 p-8 z-20">
                    <h3
                        class="font-[var(--theme-font-title)] text-5xl text-white mb-2 drop-shadow-md"
                    >
                        CUMPLEAÑOS
                    </h3>
                    <p class="text-gray-200 leading-snug font-medium">
                        El festejado no paga. Pastel permitido.
                    </p>
                </div>
            </div>

            <!-- OFFICE / BIG GROUPS -->
            <div
                class="group relative aspect-[3/4] rounded-3xl overflow-hidden border transition-colors duration-300 bg-[var(--theme-card-bg)] border-[var(--theme-border)] hover:border-[var(--theme-accent)] shadow-lg hover:shadow-xl"
            >
                <div
                    class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent z-10 pointer-events-none"
                >
                </div>
                <div
                    class="absolute inset-0 bg-cover bg-center opacity-100 group-hover:scale-105 transition-transform duration-700 theme-bg-image"
                    style={`--bg-light: url('${bgOfficeM.src}'); --bg-dark: url('${bgOfficeN.src}');`}
                >
                </div>

                <div class="absolute bottom-0 left-0 p-8 z-20">
                    <h3
                        class="font-[var(--theme-font-title)] text-5xl text-white mb-2 drop-shadow-md"
                    >
                        OFICINA & GRUPOS
                    </h3>
                    <p class="text-gray-200 leading-snug font-medium">
                        Paquetes de Sliders y Alitas para compartir.
                    </p>
                </div>
            </div>

            <!-- FULL HOUSE -->
            <div
                class="group relative aspect-[3/4] rounded-3xl overflow-hidden border transition-colors duration-300 bg-[var(--theme-card-bg)] border-[var(--theme-border)] hover:border-[var(--theme-accent)] shadow-lg hover:shadow-xl"
            >
                <div
                    class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent z-10 pointer-events-none"
                >
                </div>
                <div
                    class="absolute inset-0 bg-cover bg-center opacity-100 group-hover:scale-105 transition-transform duration-700 theme-bg-image"
                    style={`--bg-light: url('${bgFullM.src}'); --bg-dark: url('${bgFullN.src}');`}
                >
                </div>

                <div class="absolute bottom-0 left-0 p-8 z-20">
                    <h3
                        class="font-[var(--theme-font-title)] text-5xl text-white mb-2 drop-shadow-md"
                    >
                        CASA LLENA
                    </h3>
                    <p class="text-gray-200 leading-snug font-medium">
                        Renta el espacio completo para tu evento privado.
                    </p>
                </div>
            </div>
        </div>

        <!-- CTA SECTION -->
        <div class="text-center pb-20 px-1 md:px-4">
            <h2
                class="text-5xl md:text-6xl mb-8"
                style="font-family: var(--theme-font-title);"
            >
                ¿Listo para armar el plan?
            </h2>
            <a
                href="mailto:contacto@gabis.com.mx"
                class="inline-block text-white text-xl md:text-2xl px-12 py-6 rounded-full hover:scale-105 transition-all shadow-xl"
                style="font-family: var(--theme-font-title); background-color: var(--theme-accent); box-shadow: 0 0 30px var(--theme-accent-alpha, rgba(0,0,0,0.2));"
            >
                COTIZAR POR CORREO
            </a>
            <p class="mt-6 opacity-60 text-sm font-medium">
                Te responderemos lo antes posible.
            </p>
        </div>
    </div>
    <Footer />
</Layout>

<style>
    .theme-bg-image {
        background-image: var(--bg-light);
    }
    :global(.dark) .theme-bg-image {
        background-image: var(--bg-dark);
    }
</style>
