---
import { HeroSlider } from "../components/HeroSlider.jsx";
import { StaggeredMenu } from "../components/StaggeredMenu.jsx";
import MenuBento from "../components/MenuBento.astro";
import { PaperMenuButton } from "../components/PaperMenuButton.jsx";
import HistorySection from "../components/HistorySection.astro";
import ReviewsSection from "../components/ReviewsSection.astro";
import LocationSection from "../components/LocationSection.astro";
import Footer from "../components/Footer.astro";
import SectionDivider from "../components/SectionDivider.astro";
import Layout from "../layouts/Layout.astro";
import { getImage } from "astro:assets";

// --- IMAGE OPTIMIZATION ---
// Import all PNGs from src/assets to generate optimized versions
const imagesGlob = import.meta.glob("../assets/images/**/*.png", {
  import: "default",
  eager: true,
});

const optimizedAssets = {};

// Process images seriously
await Promise.all(
  Object.entries(imagesGlob).map(async ([path, image]) => {
    const filename = path.split("/").pop();
    const optimized = await getImage({
      src: image,
      format: "avif",
      quality: 80,
    });
    optimizedAssets[filename] = optimized.src;
  }),
);
---

<Layout title="Gabis | Birria y Alitas">
  <main class="min-h-screen bg-neutral-950">
    <!-- HERO -->
    <HeroSlider client:load optimizedImages={optimizedAssets} />

    <!-- MENU EXPERIENCIAL (BENTO GRID) -->
    <MenuBento />

    <!-- DIVIDER -->
    <SectionDivider />

    <!-- HISTORY SECTION (Static) -->
    <HistorySection />

    <!-- DIVIDER -->
    <SectionDivider />

    <!-- REVIEWS SECTION (Static) -->
    <ReviewsSection />

    <!-- DIVIDER -->
    <SectionDivider />

    <!-- DIVIDER -->

    <!-- LOCATION SECTION (Static + Iframe map) -->
    <LocationSection />

    <!-- DIVIDER -->
    <SectionDivider />

    <!-- FOOTER (Static) -->
    <Footer />
  </main>
</Layout>
